{
  "compilerOptions": {
    "target": "es2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./*"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "next-env.d.ts",
    "app/layout.tsx",
    "app/page.tsx",
    "components/EventFeed.tsx",
    "components/PnlChart.tsx",
    "components/PointsPanel.tsx",
    "components/PositionsTable.tsx",
    "components/StatusCard.tsx",
    "components/TradeTable.tsx",
    "lib/api.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src",
    "components/AirdropScore.tsx",
    "components/BotControls.tsx",
    "components/PnLChart.tsx",
    "components/StatCard.tsx",
    "components/TradeHistory.tsx",
    "lib/hooks.ts"
  ]
}
