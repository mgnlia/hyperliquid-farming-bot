# Hyperliquid Farming Bot — Environment Variables
# Copy to .env and fill in values

# ── Mode ──────────────────────────────────────────────────────────────────────
SIMULATION_MODE=true          # Set false for live trading

# ── Wallet (NEVER commit real keys) ──────────────────────────────────────────
PRIVATE_KEY=                  # Your wallet private key
WALLET_ADDRESS=               # Your wallet address (0x...)

# ── Hyperliquid ───────────────────────────────────────────────────────────────
HL_API_URL=https://api.hyperliquid.xyz
HL_TESTNET=false

# ── HyperEVM ─────────────────────────────────────────────────────────────────
HYPEREVM_RPC=https://rpc.hyperliquid.xyz/evm

# ── Strategy Toggles ─────────────────────────────────────────────────────────
ENABLE_PERPS=true
ENABLE_DEFI=true
ENABLE_POINTS=true

# ── Risk ──────────────────────────────────────────────────────────────────────
MAX_POSITION_USD=500
MAX_TOTAL_EXPOSURE_USD=2000
MAX_DRAWDOWN_PCT=0.10
MAX_LEVERAGE=3.0

# ── Perps ─────────────────────────────────────────────────────────────────────
PERPS_TRADE_SIZE_USD=50
PERPS_INTERVAL_SECONDS=300

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
